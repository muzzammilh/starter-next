# App
NEXT_PUBLIC_APP_NAME="Your App Name"
NEXT_PUBLIC_APP_DESCRIPTION="Your app description"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Authentication
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# OAuth Providers (Optional - set ENABLE flag to "true" and add credentials)
# Google OAuth - https://console.cloud.google.com/apis/credentials
ENABLE_GOOGLE_AUTH="false"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Facebook OAuth - https://developers.facebook.com/apps
ENABLE_FACEBOOK_AUTH="false"
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# Apple OAuth - https://developer.apple.com/account/resources/identifiers/list/serviceId
ENABLE_APPLE_AUTH="false"
# APPLE_ID=""
# APPLE_SECRET=""

# X (Twitter) OAuth - https://developer.twitter.com/en/portal/dashboard
ENABLE_TWITTER_AUTH="false"
# TWITTER_CLIENT_ID=""
# TWITTER_CLIENT_SECRET=""

# GitHub OAuth - https://github.com/settings/developers
ENABLE_GITHUB_AUTH="false"
# GITHUB_ID=""
# GITHUB_SECRET=""

# Email Provider (Optional - for magic link authentication)
# Set ENABLE flag to "true" and configure EMAIL_SERVER and EMAIL_FROM
ENABLE_EMAIL_AUTH="false"
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="noreply@example.com"

# Credentials Provider (Optional - for email/password authentication)
# Set to "true" to enable custom credentials authentication
# You must implement the authorize logic in lib/auth/options.ts
# ENABLE_CREDENTIALS_AUTH="false"

# Logging
# Log level: trace, debug, info, warn, error, fatal
# Default: debug in development, info in production
LOG_LEVEL="debug"

# File Logging (Django-style with rotation)
# Enable file logging (logs will be written to files in addition to stdout)
LOG_TO_FILE="false"

# Log directory (relative to project root)
LOG_DIR="./logs"

# Rotation policy - size-based
# Max file size before rotation (supports: 10M, 100K, 1G)
LOG_FILE_MAX_SIZE="10M"

# Max number of rotated log files to keep
LOG_FILE_MAX_FILES="10"

# Rotation policy - time-based (optional, use instead of or with size-based)
# Max age of log files (supports: 7d, 24h, 60m)
# LOG_FILE_MAX_AGE="7d"

# Email (Optional - auto-detects provider, see README for setup)
# SMTP (Gmail, Outlook, etc.)
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASSWORD="your-app-password"
# EMAIL_FROM="Your App <noreply@yourapp.com>"

# Or use API-based providers (Resend, SendGrid, Mailjet)
# Resend - https://resend.com
# RESEND_API_KEY=""
# RESEND_API_URL="https://api.resend.com/emails"

# SendGrid - https://sendgrid.com
# SENDGRID_API_KEY=""
# SENDGRID_API_URL="https://api.sendgrid.com/v3/mail/send"

# Mailjet - https://mailjet.com
# MAILJET_API_KEY=""
# MAILJET_API_SECRET=""
# MAILJET_API_URL="https://api.mailjet.com/v3.1/send"

# Email test endpoint (disabled in production by default)
# ENABLE_EMAIL_TEST_ENDPOINT="false"

# API Middleware (Optional - uses defaults if not set)
# Rate limiting
# RATE_LIMIT_MAX_REQUESTS="100"
# RATE_LIMIT_WINDOW_MS="60000"

# CORS allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS="https://example.com,https://app.example.com"

# Redis for distributed rate limiting (optional, for multi-instance deployments)
# REDIS_URL="redis://localhost:6379"

# File Upload / Storage
# Storage provider: local, s3, cloudinary
STORAGE_PROVIDER="local"

# Local storage (default)
UPLOAD_DIR="./public/uploads"

# AWS S3 (optional - for production)
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="your-bucket-name"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_ENDPOINT="" # Optional: for S3-compatible services (DigitalOcean Spaces, MinIO)

# Cloudinary (optional - for media-heavy apps)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
# CLOUDINARY_FOLDER="uploads"

# File size limits (optional - uses defaults if not set)
# Supports formats: 5MB, 10M, 100KB, 1GB
# MAX_IMAGE_SIZE="5MB"    # Default: 5MB for images
# MAX_FILE_SIZE="10MB"    # Default: 10MB for other files
