# App
NEXT_PUBLIC_APP_NAME="Your App Name"
NEXT_PUBLIC_APP_DESCRIPTION="Your app description"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./data/local.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Authentication
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# OAuth Providers (Optional - set ENABLE flag to "true" and add credentials)
# Google OAuth - https://console.cloud.google.com/apis/credentials
ENABLE_GOOGLE_AUTH="false"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Facebook OAuth - https://developers.facebook.com/apps
ENABLE_FACEBOOK_AUTH="false"
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""

# Apple OAuth - https://developer.apple.com/account/resources/identifiers/list/serviceId
ENABLE_APPLE_AUTH="false"
# APPLE_ID=""
# APPLE_SECRET=""

# X (Twitter) OAuth - https://developer.twitter.com/en/portal/dashboard
ENABLE_TWITTER_AUTH="false"
# TWITTER_CLIENT_ID=""
# TWITTER_CLIENT_SECRET=""

# GitHub OAuth - https://github.com/settings/developers
ENABLE_GITHUB_AUTH="false"
# GITHUB_ID=""
# GITHUB_SECRET=""

# Email Provider (Optional - for magic link authentication)
# Set ENABLE flag to "true" and configure EMAIL_SERVER and EMAIL_FROM
ENABLE_EMAIL_AUTH="false"
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="noreply@example.com"

# Credentials Provider (Optional - for email/password authentication)
# Set to "true" to enable custom credentials authentication
# You must implement the authorize logic in lib/auth/options.ts
# ENABLE_CREDENTIALS_AUTH="false"
